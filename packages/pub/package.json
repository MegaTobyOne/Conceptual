{
  "name": "pspf-pub",
  "displayName": "PSPF Pub",
  "description": "PSPF people, role, team, assignment, and stakeholder relationship surface.",
  "version": "1.41.2",
  "private": true,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MegaTobyOne/Conceptual.git",
    "directory": "packages/pub"
  },
  "publisher": "tobyharvey",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "extensionDependencies": [
    "tobyharvey.pspf-core"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "pspfPub",
          "title": "PSPF Pub",
          "icon": "resources/pub.svg"
        }
      ]
    },
    "views": {
      "pspfPub": [
        {
          "type": "webview",
          "id": "pspfPub.homeView",
          "name": "Pub Home"
        },
        {
          "id": "pspfPub.peopleView",
          "name": "People",
          "visibility": "collapsed"
        },
        {
          "id": "pspfPub.teamsView",
          "name": "Teams",
          "visibility": "collapsed"
        },
        {
          "id": "pspfPub.rolesView",
          "name": "Roles",
          "visibility": "collapsed"
        },
        {
          "id": "pspfPub.assignmentsView",
          "name": "Assignments",
          "visibility": "collapsed"
        }
      ]
    },
    "commands": [
      {
        "command": "pspf.pub.openHome",
        "title": "PSPF: Open Pub"
      },
      {
        "command": "pspf.pub.loadSample",
        "title": "PSPF: Load Pub Sample"
      },
      {
        "command": "pspf.pub.newPerson",
        "title": "PSPF: New Pub Person"
      },
      {
        "command": "pspf.pub.openPersonDetail",
        "title": "PSPF: Open Pub Person Detail"
      },
      {
        "command": "pspf.pub.editPerson",
        "title": "PSPF: Edit Pub Person"
      },
      {
        "command": "pspf.pub.newTeam",
        "title": "PSPF: New Pub Team"
      },
      {
        "command": "pspf.pub.openTeamDetail",
        "title": "PSPF: Open Pub Team Detail"
      },
      {
        "command": "pspf.pub.editTeam",
        "title": "PSPF: Edit Pub Team"
      },
      {
        "command": "pspf.pub.exportTeamScopeBrief",
        "title": "PSPF: Export Pub Team Scope Brief"
      },
      {
        "command": "pspf.pub.openTeamResponsibilitySummary",
        "title": "PSPF: Open Pub Team Responsibility Summary"
      },
      {
        "command": "pspf.pub.openTeamResponsibilityDetail",
        "title": "PSPF: Open Pub Team Responsibility Detail"
      },
      {
        "command": "pspf.pub.newRole",
        "title": "PSPF: New Pub Role"
      },
      {
        "command": "pspf.pub.openRoleDetail",
        "title": "PSPF: Open Pub Role Detail"
      },
      {
        "command": "pspf.pub.editRole",
        "title": "PSPF: Edit Pub Role"
      },
      {
        "command": "pspf.pub.newAssignment",
        "title": "PSPF: New Pub Assignment"
      },
      {
        "command": "pspf.pub.openAssignmentDetail",
        "title": "PSPF: Open Pub Assignment Detail"
      },
      {
        "command": "pspf.pub.editAssignment",
        "title": "PSPF: Edit Pub Assignment"
      },
      {
        "command": "pspf.pub.recordRelationshipNote",
        "title": "PSPF: Record Pub Relationship Note"
      },
      {
        "command": "pspf.pub.openRelationshipNoteDetail",
        "title": "PSPF: Open Pub Relationship Note Detail"
      },
      {
        "command": "pspf.pub.editRelationshipNote",
        "title": "PSPF: Edit Pub Relationship Note"
      },
      {
        "command": "pspf.pub.openOrgChart",
        "title": "PSPF: Open Pub Organisation Chart"
      },
      {
        "command": "pspf.pub.openPeople",
        "title": "PSPF: Open Pub People"
      },
      {
        "command": "pspf.pub.openTeams",
        "title": "PSPF: Open Pub Teams"
      },
      {
        "command": "pspf.pub.openRoles",
        "title": "PSPF: Open Pub Roles"
      },
      {
        "command": "pspf.pub.openAssignments",
        "title": "PSPF: Open Pub Assignments"
      },
      {
        "command": "pspf.pub.openRelationshipLog",
        "title": "PSPF: Open Pub Relationship Log"
      },
      {
        "command": "pspf.pub.openPeopleCulture",
        "title": "PSPF: Open Pub People and Culture"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "pspf.pub.newPerson",
          "when": "view == pspfPub.peopleView",
          "group": "navigation@1"
        },
        {
          "command": "pspf.pub.openPeople",
          "when": "view == pspfPub.peopleView",
          "group": "navigation@2"
        },
        {
          "command": "pspf.pub.editPerson",
          "when": "view == pspfPub.peopleView",
          "group": "navigation@3"
        },
        {
          "command": "pspf.pub.newTeam",
          "when": "view == pspfPub.teamsView",
          "group": "navigation@1"
        },
        {
          "command": "pspf.pub.openTeams",
          "when": "view == pspfPub.teamsView",
          "group": "navigation@2"
        },
        {
          "command": "pspf.pub.editTeam",
          "when": "view == pspfPub.teamsView",
          "group": "navigation@3"
        },
        {
          "command": "pspf.pub.openTeamResponsibilitySummary",
          "when": "view == pspfPub.teamsView",
          "group": "navigation@4"
        },
        {
          "command": "pspf.pub.openTeamResponsibilityDetail",
          "when": "view == pspfPub.teamsView",
          "group": "navigation@5"
        },
        {
          "command": "pspf.pub.newRole",
          "when": "view == pspfPub.rolesView",
          "group": "navigation@1"
        },
        {
          "command": "pspf.pub.openRoles",
          "when": "view == pspfPub.rolesView",
          "group": "navigation@2"
        },
        {
          "command": "pspf.pub.editRole",
          "when": "view == pspfPub.rolesView",
          "group": "navigation@3"
        },
        {
          "command": "pspf.pub.newAssignment",
          "when": "view == pspfPub.assignmentsView",
          "group": "navigation@1"
        },
        {
          "command": "pspf.pub.openAssignments",
          "when": "view == pspfPub.assignmentsView",
          "group": "navigation@2"
        },
        {
          "command": "pspf.pub.recordRelationshipNote",
          "when": "view == pspfPub.homeView",
          "group": "navigation@1"
        },
        {
          "command": "pspf.pub.openOrgChart",
          "when": "view == pspfPub.homeView",
          "group": "navigation@2"
        },
        {
          "command": "pspf.pub.openPeopleCulture",
          "when": "view == pspfPub.homeView",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "pspf.pub.openPersonDetail",
          "when": "view == pspfPub.peopleView && viewItem == pspfPubPerson",
          "group": "0_open@1"
        },
        {
          "command": "pspf.pub.editPerson",
          "when": "view == pspfPub.peopleView && viewItem == pspfPubPerson",
          "group": "1_modify@1"
        },
        {
          "command": "pspf.pub.openTeamDetail",
          "when": "view == pspfPub.teamsView && viewItem == pspfPubTeam",
          "group": "0_open@1"
        },
        {
          "command": "pspf.pub.editTeam",
          "when": "view == pspfPub.teamsView && viewItem == pspfPubTeam",
          "group": "1_modify@1"
        },
        {
          "command": "pspf.pub.exportTeamScopeBrief",
          "when": "view == pspfPub.teamsView && viewItem == pspfPubTeam",
          "group": "1_modify@2"
        },
        {
          "command": "pspf.pub.openRoleDetail",
          "when": "view == pspfPub.rolesView && viewItem == pspfPubRole",
          "group": "0_open@1"
        },
        {
          "command": "pspf.pub.editRole",
          "when": "view == pspfPub.rolesView && viewItem == pspfPubRole",
          "group": "1_modify@1"
        },
        {
          "command": "pspf.pub.openAssignmentDetail",
          "when": "view == pspfPub.assignmentsView && viewItem == pspfPubAssignment",
          "group": "0_open@1"
        },
        {
          "command": "pspf.pub.editAssignment",
          "when": "view == pspfPub.assignmentsView && viewItem == pspfPubAssignment",
          "group": "1_modify@1"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && pnpm exec esbuild src/extension.ts --bundle --platform=node --format=esm --target=node22 --external:vscode --outfile=dist/extension.js",
    "test": "node --test dist/**/*.test.js"
  },
  "dependencies": {
    "@pspf/contracts": "workspace:*",
    "@pspf/webview-shell": "workspace:*"
  }
}
