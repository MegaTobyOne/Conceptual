    "menus": {
      "commandPalette": [
        {
          "command": "pspf.workshop.openTreeEntity",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "pspf.workshop.createRequirement",
          "when": "view == pspfWorkshop.requirementsView",
          "group": "navigation@1"
        },
        {
          "command": "pspf.workshop.attachEvidence",
          "when": "view == pspfWorkshop.evidenceView",
          "group": "navigation@1"
        },
        {
          "command": "pspf.workshop.createAction",
          "when": "view == pspfWorkshop.actionsView",
          "group": "navigation@1"
        },
        {
          "command": "pspf.workshop.createRisk",
          "when": "view == pspfWorkshop.risksView",
          "group": "navigation@1"
        },
        {
          "command": "pspf.workshop.registerDirection",
          "when": "view == pspfWorkshop.directionsView",
          "group": "navigation@1"
        },
        {
          "command": "pspf.workshop.importBundle",
          "when": "view == pspfWorkshop.homeView",
          "group": "navigation@1"
        },
        {
          "command": "pspf.workshop.exportBackupJson",
          "when": "view == pspfWorkshop.homeView",
          "group": "navigation@1.1"
        },
        {
          "command": "pspf.workshop.importBackupJson",
          "when": "view == pspfWorkshop.homeView",
          "group": "navigation@1.2"
        },
        {
          "command": "pspf.workshop.loadSampleWorkspace",
          "when": "view == pspfWorkshop.homeView",
          "group": "navigation@2"
        },
        {
          "command": "pspf.workshop.manageTags",
          "when": "view == pspfWorkshop.homeView",
          "group": "navigation@3"
        },
        {
          "command": "pspf.workshop.openChangeRecords",
          "when": "view == pspfWorkshop.homeView",
          "group": "navigation@4"
        },
        {
          "command": "pspf.workshop.openMasterDashboard",
          "when": "view == pspfWorkshop.homeView",
          "group": "navigation@4.5"
        },
        {
          "command": "pspf.workshop.openPspfGridView",
          "when": "view == pspfWorkshop.homeView",
          "group": "navigation@4.55"
        },
        {
          "command": "pspf.workshop.openHumanCentredRiskView",
          "when": "view == pspfWorkshop.homeView",
          "group": "navigation@4.56"
        },
        {
          "command": "pspf.workshop.openContinuousComplianceMetro",
          "when": "view == pspfWorkshop.homeView",
          "group": "navigation@4.57"
        },
        {
          "command": "pspf.workshop.openUnifiedSecurityOperatingModel",
          "when": "view == pspfWorkshop.homeView",
          "group": "navigation@4.58"
        },
        {
          "command": "pspf.workshop.openCyberAwarenessChangeStrategy",
          "when": "view == pspfWorkshop.homeView",
          "group": "navigation@4.59"
        },
        {
          "command": "pspf.workshop.openPentestWorkbench",
          "when": "view == pspfWorkshop.homeView",
          "group": "navigation@4.595"
        },
        {
          "command": "pspf.workshop.openRequirementCardView",
          "when": "view == pspfWorkshop.homeView",
          "group": "navigation@4.597"
        },
        {
          "command": "pspf.workshop.openPlanOfActionBoard",
          "when": "view == pspfWorkshop.homeView",
          "group": "navigation@4.6"
        },
        {
          "command": "pspf.workshop.openCisoNewsletterReview",
          "when": "view == pspfWorkshop.homeView",
          "group": "navigation@4.65"
        },
        {
          "command": "pspf.workshop.openCisoMagazine",
          "when": "view == pspfWorkshop.homeView",
          "group": "navigation@4.7"
        },
        {
          "command": "pspf.workshop.openCisoMasterPlan",
          "when": "view == pspfWorkshop.homeView",
          "group": "navigation@4.8"
        },
        {
          "command": "pspf.workshop.openConnectedView",
          "when": "view == pspfWorkshop.homeView",
          "group": "navigation@5"
        },
        {
          "command": "pspf.workshop.manageSavedViews",
          "when": "view == pspfWorkshop.homeView",
          "group": "navigation@6"
        }
      ],
      "view/item/context": [
        {
          "command": "pspf.workshop.openTreeEntity",
          "when": "view == pspfWorkshop.requirementsView && viewItem == pspfWorkshopRequirement",
          "group": "0_open@1"
        },
        {
          "command": "pspf.workshop.openTreeEntity",
          "when": "view == pspfWorkshop.evidenceView && viewItem == pspfWorkshopEvidence",
          "group": "0_open@1"
        },
        {
          "command": "pspf.workshop.openTreeEntity",
          "when": "view == pspfWorkshop.actionsView && viewItem == pspfWorkshopAction",
          "group": "0_open@1"
        },
        {
          "command": "pspf.workshop.openTreeEntity",
          "when": "view == pspfWorkshop.risksView && viewItem == pspfWorkshopRisk",
          "group": "0_open@1"
        },
        {
          "command": "pspf.workshop.openTreeEntity",
          "when": "view == pspfWorkshop.directionsView && viewItem == pspfWorkshopDirection",
          "group": "0_open@1"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && pnpm exec esbuild src/extension.ts --bundle --platform=node --format=esm --target=node22 --external:vscode --outfile=dist/extension.js",
    "test": "node --test dist/*.test.js dist/**/*.test.js"
  },
  "dependencies": {
    "@pspf/brief-renderer": "workspace:*",
    "@pspf/connected-view": "workspace:*",
    "@pspf/contracts": "workspace:*",
    "@pspf/reference-data": "workspace:*",
    "@pspf/webview-shell": "workspace:*"
  }
}
