{
  "name": "pspf-core",
  "displayName": "PSPF Core",
  "description": "Local PSPF system of record, workspace bootstrap, validation, snapshots, and export operations.",
  "version": "1.31.2",
  "private": true,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MegaTobyOne/Conceptual.git",
    "directory": "packages/core"
  },
  "publisher": "tobyharvey",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:.pspf/config/workspace.json",
    "workspaceContains:.pspf/core/pspf-core.db"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "PSPF Core",
      "properties": {
        "pspf.core.initialiseOnActivation": {
          "type": "boolean",
          "default": false,
          "description": "Initialise the PSPF workspace automatically when PSPF Core activates. Intended for trusted debug or dedicated PSPF workspaces."
        }
      }
    },
    "commands": [
      {
        "command": "pspf.core.initialiseWorkspace",
        "title": "PSPF: Initialise PSPF Workspace"
      },
      {
        "command": "pspf.core.validateWorkspace",
        "title": "PSPF: Validate Workspace"
      },
      {
        "command": "pspf.core.verifyIntegrity",
        "title": "PSPF: Verify Integrity"
      },
      {
        "command": "pspf.core.runIntegrityScan",
        "title": "PSPF: Run Integrity Scan"
      },
      {
        "command": "pspf.core.createSnapshot",
        "title": "PSPF: Create Snapshot"
      },
      {
        "command": "pspf.core.exportBundle",
        "title": "PSPF: Export Master Bundle"
      },
      {
        "command": "pspf.core.importBundle",
        "title": "PSPF: Import Master Bundle"
      },
      {
        "command": "pspf.core.importExplorerLocalBundle",
        "title": "PSPF: Import Explorer Local JSON"
      },
      {
        "command": "pspf.core.undoLastImport",
        "title": "PSPF: Undo Last Import"
      },
      {
        "command": "pspf.core.showWriterLock",
        "title": "PSPF: Show Writer Lock"
      }
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && pnpm exec esbuild src/extension.ts --bundle --platform=node --format=esm --target=node22 --external:vscode --banner:js='import { createRequire as __pspfCreateRequire } from \"node:module\"; import { fileURLToPath as __pspfFileURLToPath } from \"node:url\"; import { dirname as __pspfDirname } from \"node:path\"; const require = __pspfCreateRequire(import.meta.url); const __filename = __pspfFileURLToPath(import.meta.url); const __dirname = __pspfDirname(__filename);' --outfile=dist/extension.js && cp ../../node_modules/sql.js/dist/sql-wasm.wasm dist/sql-wasm.wasm",
    "test": "node --test dist/**/*.test.js"
  },
  "dependencies": {
    "@pspf/contracts": "workspace:*",
    "@pspf/ism-source-library": "workspace:*",
    "@pspf/reference-data": "workspace:*",
    "@pspf/webview-shell": "workspace:*",
    "sql.js": "^1.14.1"
  }
}
