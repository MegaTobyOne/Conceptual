{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://pspf.local/schemas/explorer-bundle/1.2.0/collections/tags.schema.json",
    "title": "PSPF Explorer Tags Collection",
    "type": "array",
    "items": {
        "type": "object",
        "required": [
            "id",
            "entityType",
            "schemaVersion",
            "title",
            "createdAt",
            "updatedAt",
            "sourceProduct",
            "recordStatus"
        ],
        "additionalProperties": false,
        "properties": {
            "id": {
                "type": "string",
                "pattern": "^TAG-"
            },
            "entityType": {
                "const": "tag"
            },
            "schemaVersion": {
                "const": "1.2.0"
            },
            "title": {
                "type": "string",
                "minLength": 1
            },
            "createdAt": {
                "type": "string",
                "format": "date-time"
            },
            "updatedAt": {
                "type": "string",
                "format": "date-time"
            },
            "sourceProduct": {
                "enum": [
                    "core",
                    "workshop",
                    "explorer"
                ]
            },
            "recordStatus": {
                "enum": [
                    "active",
                    "archived",
                    "inactive",
                    "deleted"
                ]
            }
        }
    }
}