{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://pspf.local/schemas/explorer-bundle/1.12.0/collections/spend-items.schema.json",
    "title": "PSPF Explorer Spend Items Collection",
    "type": "array",
    "items": {
        "type": "object",
        "required": [
            "id",
            "entityType",
            "schemaVersion",
            "title",
            "createdAt",
            "updatedAt",
            "sourceProduct",
            "recordStatus",
            "spendType",
            "status",
            "financialYear"
        ],
        "additionalProperties": false,
        "properties": {
            "id": {
                "type": "string",
                "pattern": "^SPD-"
            },
            "entityType": {
                "const": "spend-item"
            },
            "schemaVersion": {
                "const": "1.12.0"
            },
            "title": {
                "type": "string",
                "minLength": 1,
                "maxLength": 160
            },
            "createdAt": {
                "type": "string",
                "format": "date-time"
            },
            "updatedAt": {
                "type": "string",
                "format": "date-time"
            },
            "sourceProduct": {
                "enum": [
                    "core",
                    "workshop",
                    "explorer",
                    "shop"
                ]
            },
            "recordStatus": {
                "enum": [
                    "active",
                    "archived",
                    "inactive",
                    "deleted"
                ]
            },
            "spendType": {
                "enum": [
                    "capex",
                    "opex",
                    "uplift",
                    "licence",
                    "service"
                ]
            },
            "status": {
                "enum": [
                    "proposed",
                    "approved",
                    "committed",
                    "spent",
                    "cancelled"
                ]
            },
            "financialYear": {
                "type": "string",
                "pattern": "^\\d{4}-\\d{2}$"
            },
            "savingsType": {
                "enum": [
                    "avoided-cost",
                    "efficiency",
                    "consolidation",
                    "risk-reduction",
                    "contract-optimisation",
                    "other"
                ]
            },
            "paybackPeriodMonths": {
                "type": "integer",
                "minimum": 0
            },
            "confidence": {
                "enum": [
                    "low",
                    "medium",
                    "high"
                ]
            }
        }
    }
}