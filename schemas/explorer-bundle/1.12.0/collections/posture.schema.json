{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://pspf.local/schemas/explorer-bundle/1.12.0/collections/posture.schema.json",
    "title": "PSPF Explorer Posture Collection",
    "type": "array",
    "minItems": 1,
    "maxItems": 1,
    "items": {
        "type": "object",
        "required": [
            "id",
            "entityType",
            "schemaVersion",
            "title",
            "createdAt",
            "updatedAt",
            "sourceProduct",
            "recordStatus",
            "requirementCount",
            "evidenceCount",
            "actionCount",
            "riskCount",
            "sourceControlCount",
            "requirementControlMappingCount",
            "changeRecordCount",
            "supplierCount",
            "contractCount",
            "spendItemCount",
            "strategyCount"
        ],
        "additionalProperties": false,
        "properties": {
            "id": {
                "const": "POSTURE"
            },
            "entityType": {
                "const": "posture"
            },
            "schemaVersion": {
                "const": "1.12.0"
            },
            "title": {
                "type": "string",
                "minLength": 1
            },
            "createdAt": {
                "type": "string",
                "format": "date-time"
            },
            "updatedAt": {
                "type": "string",
                "format": "date-time"
            },
            "sourceProduct": {
                "enum": [
                    "core",
                    "workshop",
                    "explorer"
                ]
            },
            "recordStatus": {
                "enum": [
                    "active",
                    "archived",
                    "inactive",
                    "deleted"
                ]
            },
            "requirementCount": {
                "type": "integer",
                "minimum": 0
            },
            "evidenceCount": {
                "type": "integer",
                "minimum": 0
            },
            "actionCount": {
                "type": "integer",
                "minimum": 0
            },
            "riskCount": {
                "type": "integer",
                "minimum": 0
            },
            "sourceControlCount": {
                "type": "integer",
                "minimum": 0
            },
            "requirementControlMappingCount": {
                "type": "integer",
                "minimum": 0
            },
            "directionCount": {
                "type": "integer",
                "minimum": 0
            },
            "changeRecordCount": {
                "type": "integer",
                "minimum": 0
            },
            "supplierCount": {
                "type": "integer",
                "minimum": 0
            },
            "contractCount": {
                "type": "integer",
                "minimum": 0
            },
            "spendItemCount": {
                "type": "integer",
                "minimum": 0
            },
            "strategyCount": {
                "type": "integer",
                "minimum": 0
            }
        }
    }
}