{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://pspf.local/schemas/explorer-bundle/1.14.0/collections/evidence.schema.json",
    "title": "PSPF Explorer Evidence Collection",
    "type": "array",
    "items": {
        "type": "object",
        "required": [
            "id",
            "entityType",
            "schemaVersion",
            "title",
            "createdAt",
            "updatedAt",
            "sourceProduct",
            "recordStatus",
            "evidenceType",
            "reference",
            "freshness"
        ],
        "additionalProperties": false,
        "properties": {
            "id": {
                "type": "string",
                "pattern": "^EVD-"
            },
            "entityType": {
                "const": "evidence"
            },
            "schemaVersion": {
                "const": "1.14.0"
            },
            "title": {
                "type": "string",
                "minLength": 1
            },
            "createdAt": {
                "type": "string",
                "format": "date-time"
            },
            "updatedAt": {
                "type": "string",
                "format": "date-time"
            },
            "sourceProduct": {
                "enum": [
                    "core",
                    "workshop",
                    "explorer"
                ]
            },
            "recordStatus": {
                "enum": [
                    "active",
                    "archived",
                    "inactive",
                    "deleted"
                ]
            },
            "evidenceType": {
                "enum": [
                    "document",
                    "url",
                    "note"
                ]
            },
            "reference": {
                "type": "string",
                "minLength": 1
            },
            "freshness": {
                "enum": [
                    "current",
                    "ageing",
                    "stale",
                    "expired",
                    "unknown"
                ]
            },
            "lifecycleStatus": {
                "enum": [
                    "active",
                    "superseded",
                    "retired"
                ]
            },
            "decisionDate": {
                "type": "string",
                "format": "date-time"
            }
        }
    }
}
