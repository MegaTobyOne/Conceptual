{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://pspf.local/schemas/explorer-bundle/1.14.0/collections/cyber-reference-mappings.schema.json",
    "title": "PSPF Explorer Cyber Reference Mappings Collection",
    "type": "array",
    "items": {
        "type": "object",
        "required": [
            "id",
            "entityType",
            "schemaVersion",
            "title",
            "createdAt",
            "updatedAt",
            "sourceProduct",
            "recordStatus",
            "from",
            "to",
            "purpose",
            "confidence",
            "provenance"
        ],
        "additionalProperties": false,
        "properties": {
            "id": {
                "type": "string",
                "pattern": "^CRM-"
            },
            "entityType": {
                "const": "cyber-reference-mapping"
            },
            "schemaVersion": {
                "const": "1.14.0"
            },
            "title": {
                "type": "string",
                "minLength": 1,
                "maxLength": 180
            },
            "createdAt": {
                "type": "string",
                "format": "date-time"
            },
            "updatedAt": {
                "type": "string",
                "format": "date-time"
            },
            "sourceProduct": {
                "enum": [
                    "core",
                    "workshop",
                    "explorer",
                    "shop"
                ]
            },
            "recordStatus": {
                "enum": [
                    "active",
                    "archived",
                    "inactive",
                    "deleted"
                ]
            },
            "from": {
                "$ref": "#/definitions/endpoint"
            },
            "to": {
                "$ref": "#/definitions/endpoint"
            },
            "purpose": {
                "enum": [
                    "implements",
                    "supports",
                    "includes",
                    "sources",
                    "themes",
                    "relates"
                ]
            },
            "coverageQualifier": {
                "enum": [
                    "primary",
                    "partial",
                    "compensating"
                ]
            },
            "applicabilityProfile": {
                "type": "string",
                "minLength": 1,
                "maxLength": 120
            },
            "confidence": {
                "enum": [
                    "low",
                    "medium",
                    "high"
                ]
            },
            "rationale": {
                "type": "string",
                "maxLength": 1200
            },
            "lastReviewedAt": {
                "type": "string",
                "format": "date-time"
            },
            "reviewBy": {
                "type": "string",
                "minLength": 1,
                "maxLength": 120
            },
            "provenance": {
                "$ref": "#/definitions/provenance"
            },
            "lifecycleStatus": {
                "enum": [
                    "active",
                    "superseded",
                    "retired"
                ]
            },
            "decisionDate": {
                "type": "string",
                "format": "date-time"
            }
        }
    },
    "definitions": {
        "endpoint": {
            "type": "object",
            "required": [
                "entityType",
                "entityId"
            ],
            "additionalProperties": false,
            "properties": {
                "entityType": {
                    "enum": [
                        "domain",
                        "requirement",
                        "evidence",
                        "action",
                        "risk",
                        "snapshot",
                        "link",
                        "tag",
                        "saved-view",
                        "source-control",
                        "requirement-control-mapping",
                        "direction",
                        "change-record",
                        "supplier",
                        "contract",
                        "spend-item",
                        "cyber-function",
                        "mitigation-strategy",
                        "guidance-framework",
                        "control-theme",
                        "cyber-reference-mapping",
                        "strategy",
                        "posture"
                    ]
                },
                "entityId": {
                    "type": "string",
                    "minLength": 1
                }
            }
        },
        "provenance": {
            "type": "object",
            "required": [
                "sourceId",
                "sourceUrl",
                "licence",
                "attribution",
                "author",
                "createdAt"
            ],
            "additionalProperties": false,
            "properties": {
                "sourceId": {
                    "type": "string",
                    "minLength": 1
                },
                "sourceUrl": {
                    "type": "string",
                    "minLength": 1
                },
                "retrievedAt": {
                    "type": "string",
                    "format": "date-time"
                },
                "licence": {
                    "type": "string",
                    "minLength": 1
                },
                "attribution": {
                    "type": "string",
                    "minLength": 1
                },
                "author": {
                    "type": "string",
                    "minLength": 1
                },
                "createdAt": {
                    "type": "string",
                    "format": "date-time"
                }
            }
        }
    }
}
