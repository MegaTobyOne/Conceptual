{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pspf.local/schemas/explorer-bundle/1.13.0/collections/guidance-frameworks.schema.json",
  "title": "PSPF Explorer Guidance Frameworks Collection",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "entityType", "schemaVersion", "title", "createdAt", "updatedAt", "sourceProduct", "recordStatus", "code", "summary", "publisher", "sourceUrl", "retrievedAt", "licence", "attribution", "sourceHash", "externalRefs", "provenance"],
    "additionalProperties": false,
    "properties": {
      "id": { "type": "string", "pattern": "^GDC-" },
      "entityType": { "const": "guidance-framework" },
      "schemaVersion": { "const": "1.13.0" },
      "title": { "type": "string", "minLength": 1, "maxLength": 180 },
      "createdAt": { "type": "string", "format": "date-time" },
      "updatedAt": { "type": "string", "format": "date-time" },
      "sourceProduct": { "enum": ["core", "workshop", "explorer", "shop"] },
      "recordStatus": { "enum": ["active", "archived", "inactive", "deleted"] },
      "code": { "type": "string", "minLength": 1, "maxLength": 80 },
      "summary": { "type": "string", "minLength": 1, "maxLength": 1200 },
      "publisher": { "type": "string", "minLength": 1, "maxLength": 120 },
      "sourceUrl": { "type": "string", "minLength": 1 },
      "retrievedAt": { "type": "string", "format": "date-time" },
      "licence": { "type": "string", "minLength": 1 },
      "attribution": { "type": "string", "minLength": 1 },
      "sourceHash": { "type": "string", "minLength": 1 },
      "externalRefs": { "$ref": "#/definitions/externalRefs" },
      "provenance": { "$ref": "#/definitions/provenance" }
    }
  },
  "definitions": {
    "externalRefs": { "type": "array", "items": { "type": "object", "required": ["scheme", "value"], "additionalProperties": false, "properties": { "scheme": { "type": "string", "minLength": 1 }, "value": { "type": "string", "minLength": 1 } } } },
    "provenance": { "type": "object", "required": ["sourceId", "sourceUrl", "licence", "attribution"], "additionalProperties": false, "properties": { "sourceId": { "type": "string", "minLength": 1 }, "sourceUrl": { "type": "string", "minLength": 1 }, "retrievedAt": { "type": "string", "format": "date-time" }, "licence": { "type": "string", "minLength": 1 }, "attribution": { "type": "string", "minLength": 1 } } }
  }
}
